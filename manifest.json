{
  "manifest_version": 3,
  "name": "Carlytics – Analyse de prix véhicules d'occasion",
  "version": "2.1",
  "description": "Analyse automatique des prix du marché véhicules d'occasion en temps réel. Détectez les meilleures opportunités d'achat, identifiez les options premium et estimez vos marges. 5 analyses gratuites.",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://api.carlytics.fr/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Carlytics",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.auto1.com/*"],
      "js": ["inject.js", "content-bridge.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["intercept.js"],
      "matches": ["https://www.auto1.com/*"]
    }
  ]
}
